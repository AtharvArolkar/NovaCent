# NovaCent core runtime
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-random-secret

# Live API mode is Phase 2 default. Set true only when doing UI-only demo work.
NEXT_PUBLIC_USE_MOCKS=false

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/novacent?retryWrites=true&w=majority
MONGODB_DB=novacent

# Google OAuth is wired but optional until credentials are created.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional email provider for password reset emails.
# If omitted, forgot-password returns a development reset link in the JSON response.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="NovaCent <no-reply@example.com>"
SMTP_ENVELOPE_FROM=
SMTP_HELO_DOMAIN=novacent.local
SUPPORT_ADMIN_EMAIL=

# Vercel Cron security for recurring expense background runs.
CRON_SECRET=replace-with-a-random-cron-secret

# OCR/background import placeholders for Phase 3. Keep disabled until configured.
OCR_ENABLED=false
OCR_LANG=eng
OCR_MAX_FILE_MB=10
OCR_WORKER_SECRET=replace-with-a-random-worker-secret

# Frankfurter needs no API key.
CURRENCY_PROVIDER=frankfurter
