NEXT_PUBLIC_USE_MOCKS=false

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-random-secret
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/novacent?retryWrites=true&w=majority
MONGODB_DB=novacent
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CURRENCY_PROVIDER=frankfurter

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="NovaCent <no-reply@example.com>"
SMTP_ENVELOPE_FROM=
SMTP_HELO_DOMAIN=novacent.local
SUPPORT_ADMIN_EMAIL=

CRON_SECRET=replace-with-a-random-cron-secret

OCR_ENABLED=false
OCR_LANG=eng
OCR_MAX_FILE_MB=10
OCR_WORKER_SECRET=replace-with-a-random-worker-secret
